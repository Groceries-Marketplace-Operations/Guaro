          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/applications",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"appId\": \"APP-MX-001\",\n  \"appName\": \"DiDi Mexico Demo\",\n  \"country\": \"MX\",\n  \"appSecret\": \"my-super-secret\"\n}" }
          }
        }
      ]
    },
    {
      "name": "Brands",
      "item": [
        {
          "name": "List brands",
          "event": [{ "listen": "test", "script": { "exec": [
            "var res = pm.response.json();",
            "if (res.length > 0) pm.collectionVariables.set('brandId', res[0].id);"
          ]}}],
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/brands",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        },
        {
          "name": "Get brand",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/brands/{{brandId}}",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        },
        {
          "name": "Create brand (auto-assigns owner)",
          "event": [{ "listen": "test", "script": { "exec": [
            "var res = pm.response.json();",
            "if (res.id) pm.collectionVariables.set('brandId', res.id);",
            "pm.test('Has owner', () => pm.expect(res.owner).to.not.be.null);"
          ]}}],
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/brands",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"brandId\": \"BRAND-CO-002\",\n  \"brandName\": \"Pizza Test CO\",\n  \"country\": \"CO\",\n  \"kaType\": \"KA\",\n  \"category\": \"Pizza\"\n}" }
          }
        },
        {
          "name": "Update brand",
          "request": {
            "method": "PATCH",
            "url": "{{baseUrl}}/brands/{{brandId}}",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"brandName\": \"Pizza Test CO (updated)\"\n}" }
          }
        },
        {
          "name": "List assignment rules",
          "event": [{ "listen": "test", "script": { "exec": [
            "var res = pm.response.json();",
            "if (res.length > 0) pm.collectionVariables.set('ruleId', res[0].id);"
          ]}}],
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/brands/assignment-rules",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        },
        {
          "name": "Update assignment rule mode",
          "request": {
            "method": "PATCH",
            "url": "{{baseUrl}}/brands/assignment-rules/{{ruleId}}",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"modo\": \"round_robin\"\n}" }
          }
        }
      ]
