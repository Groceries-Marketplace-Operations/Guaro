    {
      "name": "Task Types",
      "item": [
        {
          "name": "List task types",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/task-types",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        },
        {
          "name": "Get task type (seed)",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/task-types/{{taskTypeId}}",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        },
        {
          "name": "Create task type",
          "event": [{ "listen": "test", "script": { "exec": [
            "var res = pm.response.json();",
            "if (res.id) pm.collectionVariables.set('newTaskTypeId', res.id);"
          ]}}],
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/task-types",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"sectionId\": \"{{sectionId}}\",\n  \"name\": \"Shop onboarding\",\n  \"description\": \"New shop onboarding flow\",\n  \"schedulable\": false\n}" }
          }
        },
        {
          "name": "Add manual step",
          "event": [{ "listen": "test", "script": { "exec": [
            "var res = pm.response.json();",
            "if (res.id) pm.collectionVariables.set('stepDefId', res.id);"
          ]}}],
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/task-types/{{newTaskTypeId}}/steps",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"Review documents\",\n  \"order\": 1,\n  \"executionType\": \"manual_internal\",\n  \"assignmentStrategy\": \"round_robin\"\n}" }
          }
        },
        {
          "name": "Add form field",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/task-types/{{newTaskTypeId}}/fields",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"label\": \"Contract URL\",\n  \"tipo\": \"link\",\n  \"required\": true,\n  \"order\": 1\n}" }
          }
        },
        {
          "name": "Add candidate to step",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/task-types/{{newTaskTypeId}}/steps/{{stepDefId}}/candidates",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"accountId\": \"<bpo-account-id>\"\n}" }
          }
        },
        {
          "name": "Add webhook to step",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/task-types/{{newTaskTypeId}}/steps/{{stepDefId}}/webhooks",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"webhookId\": \"{{webhookId}}\",\n  \"events\": [\"on_start\", \"on_complete\", \"on_fail\"]\n}" }
          }
        }
      ]
    },
