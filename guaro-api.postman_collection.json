    {
      "name": "Invitations",
      "item": [
        {
          "name": "Create invitation (bpo)",
          "event": [{ "listen": "test", "script": { "exec": [
            "var res = pm.response.json();",
            "if (res.token) pm.collectionVariables.set('invitationToken', res.token);",
            "pm.test('Created', () => pm.response.to.have.status(201));"
          ]}}],
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/invitations",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"rol\": \"bpo\",\n  \"sectionId\": \"{{sectionId}}\"\n}" }
          }
        },
        {
          "name": "List invitations",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/invitations",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        },
        {
          "name": "Use invitation",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/invitations/{{invitationToken}}/use",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"nombre\": \"New BPO\"\n}" }
          }
        }
      ]
    },
