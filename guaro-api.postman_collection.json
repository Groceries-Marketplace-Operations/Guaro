    {
      "name": "Shops",
      "item": [
        {
          "name": "List shops",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/shops",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        },
        {
          "name": "List shops by brand",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/shops?brandId={{brandId}}",
              "host": ["{{baseUrl}}"],
              "path": ["shops"],
              "query": [{ "key": "brandId", "value": "{{brandId}}" }]
            },
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        },
        {
          "name": "Create shop",
          "event": [{ "listen": "test", "script": { "exec": [
            "var res = pm.response.json();",
            "if (res.id) pm.collectionVariables.set('shopId', res.id);"
          ]}}],
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/shops",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"shopId\": \"SHOP-CO-010\",\n  \"appShopId\": \"S010\",\n  \"brandId\": \"{{brandId}}\",\n  \"city\": \"Medellin\",\n  \"latitude\": \"6.2476\",\n  \"longitude\": \"-75.5658\"\n}" }
          }
        },
        {
          "name": "Update shop status",
          "request": {
            "method": "PATCH",
            "url": "{{baseUrl}}/shops/{{shopId}}",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"status\": \"application\"\n}" }
          }
        },
        {
          "name": "Add schedule",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/shops/{{shopId}}/schedules",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"day\": \"monday\",\n  \"openTime\": \"08:00\",\n  \"closeTime\": \"22:00\"\n}" }
          }
        }
      ]
    },
    {
      "name": "Tasks",
      "item": [
        {
          "name": "List tasks",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/tasks",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        },
        {
          "name": "Create task (immediate)",
          "event": [{ "listen": "test", "script": { "exec": [
            "var res = pm.response.json();",
            "if (res.id) pm.collectionVariables.set('taskId', res.id);",
            "if (res.stepInstances) {",
            "  var active = res.stepInstances.find(s => s.status === 'in_progress');",
            "  if (active) pm.collectionVariables.set('stepId', active.id);",
            "}",
            "pm.test('Task created', () => pm.response.to.have.status(201));"
          ]}}],
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/tasks",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"taskTypeId\": \"{{taskTypeId}}\",\n  \"brandId\": \"{{brandId}}\"\n}" }
          }
        },
        {
          "name": "Create scheduled task",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/tasks",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"taskTypeId\": \"{{taskTypeId}}\",\n  \"brandId\": \"{{brandId}}\",\n  \"scheduledStart\": \"2026-06-14T08:00:00.000Z\",\n  \"scheduledEnd\": \"2026-06-14T18:00:00.000Z\"\n}" }
          }
        },
        {
          "name": "Get task",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/tasks/{{taskId}}",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        },
        {
          "name": "Complete step",
          "request": {
            "method": "PATCH",
            "url": "{{baseUrl}}/tasks/{{taskId}}/steps/{{stepId}}/complete",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"note\": \"Credentials validated successfully\"\n}" }
          }
        },
        {
          "name": "Block step",
          "request": {
            "method": "PATCH",
            "url": "{{baseUrl}}/tasks/{{taskId}}/steps/{{stepId}}/block",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"note\": \"Missing client documentation\"\n}" }
          }
        },
        {
          "name": "Retry blocked step",
          "request": {
            "method": "PATCH",
            "url": "{{baseUrl}}/tasks/{{taskId}}/steps/{{stepId}}/retry",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        },
        {
          "name": "Fail step",
          "request": {
            "method": "PATCH",
            "url": "{{baseUrl}}/tasks/{{taskId}}/steps/{{stepId}}/fail",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"failureReason\": \"bpo_timed_out\",\n  \"note\": \"Did not respond within the window\"\n}" }
          }
        }
      ]
    },
